{
  "hosting": [
    {
      "target": "prod",
      "public": "dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "**/*.@(eot|otf|ttf|ttc|woff|font.css)",
          "headers": [ { "key": "Access-Control-Allow-Origin", "value": "*" } ]
        },
        {
          "source": "index.html",
          "headers": [ { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" } ]
        }
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "dev",
      "public": "dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "**/*.@(eot|otf|ttf|ttc|woff|font.css)",
          "headers": [ { "key": "Access-Control-Allow-Origin", "value": "*" } ]
        },
        {
          "source": "index.html",
          "headers": [ { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" } ]
        }
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ]
}
